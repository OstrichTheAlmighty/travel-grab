# Duffel API key — required for flight search
DUFFEL_API_KEY=

# OpenAI API key — optional; enables AI-generated flight explanations
# Falls back to deterministic explanations if missing or on error
OPENAI_API_KEY=

# Google Places API key — required for hotel geo-filtering and activities search
# Must be enabled for: Geocoding API, Places API, Maps JavaScript API
# Never expose this key to the browser — read only via server-side process.env
GOOGLE_PLACES_API_KEY=

# SerpAPI key — required for hotel search results
SERPAPI_API_KEY=

# PostgreSQL connection string — required for trips, itinerary, and saved activities
# Use Neon (neon.tech) or any Postgres 15+ host
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Demo gate — controls public access to /flights, /hotels, /activities, /itinerary
# Set NEXT_PUBLIC_DEMO_ENABLED=true to allow all visitors (bypasses gate entirely)
# Leave false for production; unlock via ?demo_key=VALUE in the URL
NEXT_PUBLIC_DEMO_ENABLED=false
# The secret key — visiting /?demo_key=VALUE stores it in localStorage for the session
# NOTE: NEXT_PUBLIC_* vars are included in the client bundle, so this is a soft gate only
NEXT_PUBLIC_DEMO_KEY=
